{
  "name": "hotel-reviews-api",
  "version": "1.0.0",
  "description": "Hotel Reviews REST API with SQLite – seeds from two CSV files",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node --max-old-space-size=6144 dist/server.js",
    "dev": "set NODE_OPTIONS=--max-old-space-size=6144&& tsx watch server.ts",
    "seed": "tsx seed.ts",
    "benchmark": "tsx lighthouse/benchmark-lighthouse.ts",
    "benchmark:smoke": "tsx lighthouse/benchmark-lighthouse.ts --smoke",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "latest",
    "cors": "^2.8.5",
    "csv-parse": "^5.5.3",
    "dotenv": "^16.4.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/node": "^24.13.3",
    "nodemon": "^3.0.3",
    "tsx": "^4.20.2",
    "typescript": "^5.9.2"
  }
}
