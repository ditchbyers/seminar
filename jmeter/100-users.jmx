  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Hotel Reviews Load Test – 100 Users" enabled="true">
      <stringProp name="TestPlan.comments">Targets /list on all 12 framework instances with 100 concurrent users</stringProp>
      <boolProp name="TestPlan.functional_mode">false</boolProp>
      <boolProp name="TestPlan.tearDown_on_shutdown">true</boolProp>
      <boolProp name="TestPlan.serialize_threadgroups">false</boolProp>
