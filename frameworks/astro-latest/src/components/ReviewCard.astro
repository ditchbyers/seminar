---
import type { Review } from '../lib/config';
export interface Props { review: Review; }
const { review } = Astro.props;
const stars = '★'.repeat(review.review_rating ?? 0) + '☆'.repeat(5 - (review.review_rating ?? 0));
---
<article class="bg-white rounded-xl shadow-sm border border-gray-100 p-5">
  <div class="flex items-start justify-between gap-2 mb-2">
    <h3 class="font-semibold text-gray-800 text-sm leading-snug">{review.review_title ?? 'Untitled'}</h3>
    <span class="text-yellow-500 text-xs whitespace-nowrap shrink-0">{stars}</span>
  </div>
  <p class="text-gray-600 text-sm line-clamp-4 mb-3">{review.review_text ?? '—'}</p>
  <div class="text-xs text-gray-400 flex flex-wrap gap-2">
    <span class="font-medium text-gray-700">{review.name ?? 'Unknown Hotel'}</span>
    {review.city && <span>· {review.city}</span>}
    {review.review_username && <span>by {review.review_username}</span>}
    {review.review_date && <span>{review.review_date.slice(0, 10)}</span>}
  </div>
</article>
