---
export interface Props {
  title: string;
}
const { title } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} – Astro v4</title>
  </head>
  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <nav class="bg-white border-b border-gray-200 px-6 py-3 flex gap-4 text-sm font-medium">
      <a href="/" class="hover:text-blue-600">Home</a>
      <a href="/text-only" class="hover:text-blue-600">Text Only</a>
      <a href="/text-images/480p" class="hover:text-blue-600">Images</a>
      <a href="/text-videos/480p" class="hover:text-blue-600">Videos</a>
      <a href="/list" class="hover:text-blue-600">List (Load Test)</a>
    </nav>
    <main class="max-w-7xl mx-auto px-4 py-8">
      <slot />
    </main>
  </body>
</html>
